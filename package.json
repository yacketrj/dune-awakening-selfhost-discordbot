{
  "name": "dune-awakening-selfhost-discordbot",
  "version": "0.1.0",
  "private": true,
  "description": "Read-only Discord bot for Dune Awakening Self-Host Docker.",
  "type": "module",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "mock:adapter": "node scripts/mock-adapter.js",
    "package:addon": "node scripts/package-addon.js",
    "register": "node scripts/register-commands.js",
    "release:check": "node scripts/validate-release.js",
    "sbom": "node scripts/generate-sbom.js",
    "test": "node --test",
    "check": "npm test && npm run release:check && npm run package:addon && npm run sbom"
  },
  "dependencies": {
    "discord.js": "^14.26.4"
  },
  "overrides": {
    "undici": "6.27.0"
  }
}
