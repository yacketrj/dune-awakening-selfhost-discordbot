# Discord application credentials.
DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_CLIENT_ID=replace-with-discord-application-client-id

# Set this while testing so slash command updates appear quickly in one guild.
DISCORD_GUILD_ID=

# RBAC is restricted by default. Configure at least one role or user before start.
DISCORD_RBAC_MODE=restricted
DISCORD_ALLOWED_USER_IDS=
DISCORD_ADMIN_ROLE_IDS=
DISCORD_OBSERVER_ROLE_IDS=replace-with-discord-observer-role-id
DISCORD_ABOUT_ROLE_IDS=
DISCORD_PING_ROLE_IDS=
DISCORD_HEALTH_ROLE_IDS=
DISCORD_STATUS_ROLE_IDS=
# Optional lower-noise aggregate status command role IDs.
DISCORD_STATUS_SUMMARY_ROLE_IDS=
DISCORD_READINESS_ROLE_IDS=
DISCORD_SERVICES_ROLE_IDS=

# Legacy alias. Prefer DISCORD_OBSERVER_ROLE_IDS for new installs.
DISCORD_ALLOWED_ROLE_IDS=

# Dune console read-only Discord adapter.
DUNE_CONSOLE_API_URL=http://console-api:3000
DUNE_DISCORD_ADAPTER_TOKEN=replace-with-console-adapter-token

# Default adapter routes.
DUNE_ADAPTER_HEALTH_PATH=/api/integrations/discord/health
DUNE_ADAPTER_STATUS_PATH=/api/integrations/discord/status
DUNE_ADAPTER_READINESS_PATH=/api/integrations/discord/readiness
DUNE_ADAPTER_SERVICES_PATH=/api/integrations/discord/services

# Default adapter methods.
DUNE_ADAPTER_HEALTH_METHOD=GET
DUNE_ADAPTER_STATUS_METHOD=POST
DUNE_ADAPTER_READINESS_METHOD=POST
DUNE_ADAPTER_SERVICES_METHOD=POST

# Keeps command output private by default. Set false for public status channels.
DISCORD_DEFAULT_EPHEMERAL=true
REQUEST_TIMEOUT_MS=8000

# Optional local container healthcheck tuning.
DUNE_BOT_HEALTH_STATE_FILE=/tmp/dune-discord-bot/health.json
DUNE_BOT_HEALTH_MAX_AGE_MS=120000
